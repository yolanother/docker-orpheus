FROM pytorch/pytorch:2.6.0-cuda12.4-cudnn9-devel

RUN apt update && \
    apt install -y espeak-ng git git-lfs ffmpeg && \
    rm -rf /var/lib/apt/lists/*
    
RUN pip3 install --upgrade --no-cache-dir torch==2.5.1 torchvision==0.20.1+cu121 torchaudio==2.5.1 --index-url https://download.pytorch.org/whl/cu121

RUN pip install huggingface_hub

# Copy API files and download script
COPY api /Orpheus-TTS

# Set up Hugging Face credentials
ARG HUGGINGFACE_TOKEN
ENV HUGGINGFACE_TOKEN=${HUGGINGFACE_TOKEN}

# Make the download script executable
RUN chmod +x /Orpheus-TTS/download_models.sh

# Download models using the script
# This is in a separate layer to optimize caching
RUN /Orpheus-TTS/download_models.sh

# Install dependencies for API
RUN pip install fastapi uvicorn pydub soundfile transformers 

# Clone Orpheus-TTS repository to a temporary location
RUN git clone https://github.com/canopyai/Orpheus-TTS /tmp/Orpheus-TTS

# Copy necessary files from the cloned repository
RUN cp -r /tmp/Orpheus-TTS/* /Orpheus-TTS/ && \
    rm -rf /tmp/Orpheus-TTS

WORKDIR /Orpheus-TTS
RUN pip install orpheus-speech
RUN pip install vllm==0.7.3

# Make port available
EXPOSE 7324

# Set PYTHONPATH
ENV PYTHONPATH=/Orpheus-TTS:/

# Create data directories
RUN mkdir -p /data/generated_audio /data/samples

# Run the API server
CMD ["sh", "-c", "python -u api.py"]